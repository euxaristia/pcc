#!/bin/bash
# PCC wrapper script - mimics gcc interface

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PCC_LIB_DIR="$SCRIPT_DIR/../lib/pcc"
PCC_BIN="$PCC_LIB_DIR/pcc"

# Detect project root and commit SHA
PROJ_ROOT="/home/euxaristia/Projects/pcc"
if [ -d "$PROJ_ROOT/.git" ]; then
    export PCC_COMMIT=$(git -C "$PROJ_ROOT" rev-parse --short HEAD 2>/dev/null || echo "unknown")
else
    export PCC_COMMIT="unknown"
fi

# Use native binary if available, otherwise fall back to bun
if [ -x "$PCC_BIN" ]; then
    PCC_RUN="$PCC_BIN"
elif [ -x "$PROJ_ROOT/pcc" ]; then
    PCC_RUN="$PROJ_ROOT/pcc"
else
    PCC_RUN="bun run $PROJ_ROOT/src/compile.ts"
fi

# Separate PCC flags from linker flags
PCC_FLAGS=()
SOURCE_FILES=()
OUTPUT_FILE=""
LINK_ARGS=()
LINK_MODE=false

while [[ $# -gt 0 ]]; do
    case $1 in
        -o)
            OUTPUT_FILE="$2"
            shift 2
            ;;
        -c|-S|-E|-g|-O*|-Wall|-Werror|-W*|-MMD|-MP|--verbose|--tokens|--help|-h|-v|-V|--version)
            PCC_FLAGS+=("$1")
            shift
            ;;
        -I*|-D*|-std=*|--arch=*)
            PCC_FLAGS+=("$1")
            shift
            ;;
        -I|-D|-MF|-std|--arch)
            PCC_FLAGS+=("$1" "$2")
            shift 2
            ;;
        *.c)
            SOURCE_FILES+=("$1")
            shift
            ;;
        *)
            # Treat remaining args as linker flags when not compiling only
            LINK_ARGS+=("$1")
            shift
            ;;
    esac
done

if [ ${#SOURCE_FILES[@]} -eq 0 ]; then
    echo "Usage: pcc [options] <source-file.c>"
    echo "Example: pcc hello.c -o hello"
    exit 1
fi

# Determine if we need to link
COMPILE_ONLY=false
for flag in "${PCC_FLAGS[@]}"; do
    if [ "$flag" = "-c" ] || [ "$flag" = "-S" ] || [ "$flag" = "-E" ]; then
        COMPILE_ONLY=true
    fi
done

OBJECT_FILES=()
COMPILE_OK=true

for src in "${SOURCE_FILES[@]}"; do
    src_flags=("${PCC_FLAGS[@]}")
    # If single source and output specified, pass -o directly
    if [ ${#SOURCE_FILES[@]} -eq 1 ] && [ -n "$OUTPUT_FILE" ]; then
        src_flags+=("-o" "$OUTPUT_FILE")
    fi

    $PCC_RUN "${src_flags[@]}" "$src"
    if [ $? -ne 0 ]; then
        COMPILE_OK=false
        break
    fi

    # Determine object file name
    if [ ${#SOURCE_FILES[@]} -eq 1 ] && [ -n "$OUTPUT_FILE" ] && [ "$COMPILE_ONLY" = true ]; then
        OBJECT_FILES+=("$OUTPUT_FILE")
    elif [ "$COMPILE_ONLY" = true ]; then
        # For -c/-S/-E without -o, pcc uses default naming
        OBJECT_FILES+=("${src%.c}.o")
    else
        OBJECT_FILES+=("${src%.c}.o")
    fi
done

if [ "$COMPILE_OK" = false ]; then
    echo "Compilation failed"
    exit 1
fi

# Link if not compile-only
if [ "$COMPILE_ONLY" = false ] && [ ${#SOURCE_FILES[@]} -gt 0 ]; then
    if [ -n "$OUTPUT_FILE" ]; then
        gcc "${OBJECT_FILES[@]}" -o "$OUTPUT_FILE" "${LINK_ARGS[@]}" 2>/dev/null
    else
        gcc "${OBJECT_FILES[@]}" -o a.out "${LINK_ARGS[@]}" 2>/dev/null
    fi

    if [ $? -eq 0 ]; then
        if [ -n "$OUTPUT_FILE" ]; then
            echo "Compilation successful: $OUTPUT_FILE"
        else
            echo "Compilation successful: a.out"
        fi
    else
        echo "Linking failed"
        exit 1
    fi
fi
